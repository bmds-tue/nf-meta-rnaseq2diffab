
nextflow_workflow {

    name "Test workflow rnaseq2diffab"
    script "../main.nf"
    workflow "rnaseq2diffab"

    test("Joins samplesheet and conditions on shared key") {

        when {
            params {
                samplesheet = "${projectDir}/testdata/samplesheet.csv"
                conditions  = "${projectDir}/testdata/conditions.csv"
                join_key    = "sample_id"
                outdir      = "${outputDir}"
            }
        }

        then {
            // ── workflow completed without error ──────────────────────────────
            assert workflow.success

            // ── output channel emits exactly one file ─────────────────────────
            assert workflow.out.merged_samplesheet        != null
            assert workflow.out.merged_samplesheet.size() == 1

            // ── inspect the file itself ───────────────────────────────────────
            def merged = path(workflow.out.merged_samplesheet.get(0))

            def lines = merged.readLines()

            // correct header: all columns from both sheets, deduplicated join key
            assert lines[0] == "sample_id,foo,bar,condition"

            // correct data row
            assert lines[1] == "s1,100,200,tumor"

            // no extra rows (header + 1 data row only)
            assert lines.size() == 2
        }
    }

    test("Matches quoted and unquoted values") {

        when {
            params {
                samplesheet = "${projectDir}/testdata/test_samplesheet.csv"
                conditions  = "${projectDir}/testdata/test_conditions.csv"
                join_key    = "sample_id"
                outdir      = "${outputDir}"
            }
        }

        then {
            // ── workflow completed without error ──────────────────────────────
            assert workflow.success

            // ── output channel emits exactly one file ─────────────────────────
            assert workflow.out.merged_samplesheet        != null
            assert workflow.out.merged_samplesheet.size() == 1
        }
    }

    test("Header row position unchanged") {

        when {
            params {
                samplesheet = "${projectDir}/testdata/test_samplesheet.csv"
                conditions  = "${projectDir}/testdata/test_conditions.csv"
                join_key    = "sample_id"
                outdir      = "${outputDir}"
            }
        }

        then {
            // ── workflow completed without error ──────────────────────────────
            assert workflow.success

            assert workflow.out.merged_samplesheet        != null
            def merged = path(workflow.out.merged_samplesheet.get(0))
            def lines = merged.readLines()

            assert lines[0] == "sample,fastq_1,fastq_2,strandedness,run_accession,experiment_accession,sample_accession,secondary_sample_accession,study_accession,secondary_study_accession,submission_accession,run_alias,experiment_alias,sample_alias,study_alias,library_layout,library_selection,library_source,library_strategy,library_name,instrument_model,instrument_platform,base_count,read_count,tax_id,scientific_name,sample_title,experiment_title,study_title,sample_description,fastq_md5,fastq_bytes,fastq_ftp,fastq_galaxy,fastq_aspera,condition"

        }
    }

    test("Fails gracefully when samplesheet is missing") {

        when {
            params {
                samplesheet = "${projectDir}/testdata/does_not_exist.csv"
                conditions  = "${projectDir}/testdata/conditions.csv"
                join_key    = "sample_id"
                outdir      = "${outputDir}"
            }
        }

        then {
            assert workflow.failed
        }
    }

}